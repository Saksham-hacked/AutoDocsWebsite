PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/autodocs-website

# Waitlist
WAITLIST_LIMIT=1000
WAITLIST_NOTIFY_EMAIL=hello@autodocs.dev

# Analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@autodocs.dev

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90
